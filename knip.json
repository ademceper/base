{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "apps/web": {
      "entry": ["app/**/page.tsx"],
      "project": ["**/*.{ts,tsx}"],
      "ignoreDependencies": ["@tailwindcss/postcss"]
    },
    "packages/ui": {
      "entry": ["src/components/*.tsx", "src/lib/*.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@tailwindcss/postcss"]
    },
    "apps/keycloak": {
      "entry": ["src/main.tsx", "src/login/KcPage.tsx"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@vitejs/plugin-react"]
    },
    "packages/ts-cfg": {
      "entry": [],
      "project": []
    }
  }
}
