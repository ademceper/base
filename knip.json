{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "apps/web": {
      "entry": ["app/**/page.tsx"],
      "project": ["**/*.{ts,tsx}"],
      "ignoreDependencies": ["@tailwindcss/postcss"]
    },
    "packages/ui": {
      "entry": ["src/components/*.tsx", "src/lib/*.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@tailwindcss/postcss", "postcss-load-config"]
    },
    "apps/keycloak": {
      "entry": [
        "src/login/KcPage.tsx",
        "src/login/KcPageStory.tsx",
        "src/**/*.stories.tsx"
      ],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["src/kc.gen.tsx"],
      "storybook": {
        "config": [".storybook/{main,preview}.{js,jsx,ts,tsx}"],
        "entry": ["src/**/*.stories.{js,jsx,ts,tsx}"]
      }
    },
    "packages/ts-cfg": {
      "entry": [],
      "project": [],
      "ignoreDependencies": ["next"]
    }
  }
}
